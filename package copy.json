{
  "name": "quiz-platform",
  "version": "1.0.0",
  "description": "Timed online quiz platform with Redis leaderboards and MongoDB persistence",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec node src/index.js",
    "start": "node src/index.js",
    "seed": "node scripts/seed-questions.js",
    "test": "jest --watch",
    "test:connections": "node scripts/test-connections.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "keywords": [
    "quiz",
    "redis",
    "mongodb",
    "real-time",
    "leaderboard"
  ],
  "author": "svnu",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.3",
    "redis": "^4.6.12",
    "uuid": "^9.0.1",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

