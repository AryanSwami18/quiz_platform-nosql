# Node environment
NODE_ENV=development
PORT=3000

# MongoDB Configuration
MONGO_USER=root
MONGO_PASSWORD=12345
MONGO_DB=quiz_platform
MONGO_URI=mongodb://root:12345@mongodb:27017/quiz_platform?authSource=admin

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Quiz Configuration
QUIZ_SESSION_TTL=3600
QUIZ_AUTO_SUBMIT_TIMEOUT=300

# API Settings
API_HOST=http://localhost:3000
API_PORT=3000

# Frontend Settings
VITE_API_URL=http://localhost:3000
